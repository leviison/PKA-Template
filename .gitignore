# PKA — Git Ignore Rules

# Team Inbox raw assets (owner-dropped files — PDFs, images, etc.)
# These are not code and can be large. Back up separately if needed.
team_inbox/

# Archive — completed/reviewed content moved out of active folders.
# archive/team_inbox/ holds binary assets (PDFs, images) — not tracked in git, same as team_inbox/.
# archive/team_comms/ and archive/owners_inbox/ hold archived briefs and deliverables —
# these ARE tracked in git so historical work survives even if the local repo is lost.
archive/team_inbox/

# Personal database — lives at ~/PKA-Data/ by default, outside this repo entirely.
# These lines are a safety guard in case of accidental path confusion.
personal.db
PKA-Data/

# Pre-migration backup files (created by ad-hoc operator backups before
# running a migration manually). The migration runner does not create these;
# the convention is operator-driven. Pattern catches any of the three tiers.
pka.db.pre_*
projects.db.pre_*
personal.db.pre_*

# Tool operational logs (local-machine state — runs of repo-resident tools).
# check_names.py appends one JSON line per run to logs/check_names.jsonl; the
# log is local-machine state used by --evaluate-demotion-criterion, not a
# durable artifact.
logs/

# pka_guard hook session-registration files. Filesystem-only session
# substrate (local-machine state, gated by SESSION_STALE_HOURS in the hook).
tools/.sessions/

# Python
__pycache__/
*.pyc
*.pyo
*.pyo
*.egg-info/
.env

# Secrets / credentials
*.env
.env.*
secrets.*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Obsidian
# PKA doubles as an Obsidian vault (open-as-vault, read-only use — viewers remain primary).
# workspace.json and workspace-mobile.json are per-user UI state — not committed.
# app.json and other settings files are intentionally NOT ignored so vault scaffold travels with the repo.
.obsidian/workspace.json
.obsidian/workspace-mobile.json
